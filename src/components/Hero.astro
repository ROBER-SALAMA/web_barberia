---
---
<section class="relative min-h-screen flex items-center overflow-hidden clip-hero" id="inicio">
  <!-- Background image with overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-black/30 z-10"></div>
  <div class="absolute inset-0"
       style="background-image: url('https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=1600&q=80'); background-size: cover; background-position: center right;">
  </div>

  <!-- Decorative vertical line -->
  <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-transparent via-brand-orange to-transparent z-20 opacity-60"></div>

  <!-- Content -->
  <div class="relative z-20 max-w-7xl mx-auto px-8 pt-32 pb-24 w-full">
    <div class="max-w-2xl">
      <p class="text-brand-orange text-xs font-semibold tracking-[0.4em] uppercase mb-6 animate-fade-in" style="opacity:0;animation-fill-mode:forwards;animation-delay:0.2s">
        — Experiencia Premium
      </p>
      <h1 class="font-display text-7xl md:text-9xl leading-none text-white mb-4 animate-fade-up" style="opacity:0;animation-fill-mode:forwards;animation-delay:0.4s">
        DOMINA<br>
        TU <span class="text-brand-orange">LOOK</span>
      </h1>
      <p class="font-heading text-xl md:text-2xl text-gray-300 italic mb-3 animate-fade-up" style="opacity:0;animation-fill-mode:forwards;animation-delay:0.6s">
        Cortes Premium,
      </p>
      <p class="font-heading text-xl md:text-2xl text-white font-bold mb-10 animate-fade-up" style="opacity:0;animation-fill-mode:forwards;animation-delay:0.7s">
        Experiencias Excepcionales
      </p>

      <div class="flex flex-wrap gap-4 animate-fade-up" style="opacity:0;animation-fill-mode:forwards;animation-delay:0.9s">
        <a href="#agendar" class="btn-primary">Agendar cita ahora</a>
        <a href="#servicios" class="btn-outline">Ver servicios</a>
      </div>

      <!-- Stats -->
      <div class="flex gap-10 mt-16 animate-fade-up" style="opacity:0;animation-fill-mode:forwards;animation-delay:1.1s">
        <div>
          <p class="font-display text-4xl text-brand-orange">12+</p>
          <p class="text-xs text-gray-400 tracking-widest uppercase mt-1">Años de experiencia</p>
        </div>
        <div class="w-px bg-brand-border"></div>
        <div>
          <p class="font-display text-4xl text-brand-orange">4.8</p>
          <p class="text-xs text-gray-400 tracking-widest uppercase mt-1">Valoración clientes</p>
        </div>
        <div class="w-px bg-brand-border"></div>
        <div>
          <p class="font-display text-4xl text-brand-orange">2K+</p>
          <p class="text-xs text-gray-400 tracking-widest uppercase mt-1">Clientes satisfechos</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 animate-pulse-slow">
    <span class="text-xs text-gray-500 tracking-widest uppercase">Scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-brand-orange to-transparent"></div>
  </div>
</section>
