---
---
<section class="py-24 px-8 relative overflow-hidden" id="agendar">
  <div class="absolute inset-0 bg-brand-orange/5 border-y border-brand-orange/10"></div>
  <!-- Decorative -->
  <div class="absolute -left-20 -top-20 w-80 h-80 rounded-full bg-brand-orange/5 blur-3xl"></div>
  <div class="absolute -right-20 -bottom-20 w-80 h-80 rounded-full bg-brand-orange/5 blur-3xl"></div>

  <div class="relative max-w-4xl mx-auto text-center" data-reveal>
    <p class="text-brand-orange text-xs font-semibold tracking-[0.4em] uppercase mb-4">— Reservas</p>
    <h2 class="font-display text-6xl md:text-8xl text-white mb-6 leading-none">
      TU PRÓXIMA<br>
      <span class="text-brand-orange">CITA</span>
    </h2>
    <p class="text-gray-400 text-base max-w-md mx-auto mb-10 leading-relaxed">
      Reserva tu lugar ahora y experimenta el nivel de servicio que mereces. Sin filas, sin esperas.
    </p>

    <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" onsubmit="return false;">
      <input
        type="tel"
        placeholder="Tu número de WhatsApp"
        class="flex-1 bg-brand-card border border-brand-border text-white placeholder-gray-600 px-5 py-3.5 text-sm rounded-sm focus:outline-none focus:border-brand-orange transition-colors"
      />
      <button type="submit" class="btn-primary whitespace-nowrap">
        Agendar cita
      </button>
    </form>

    <p class="text-xs text-gray-600 mt-4">O llámanos directamente al <a href="tel:+50322345678" class="text-brand-orange hover:underline">+503 2234-5678</a></p>
  </div>
</section>
