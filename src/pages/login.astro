---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Crear cuenta - Legend Barber">
  <Navbar />
  <main class="min-h-screen bg-brand-dark">
    <div class="max-w-6xl min-h-screen mx-auto flex items-center">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div data-reveal class="space-y-6">
          <div>
            <p
              class="text-orange-500 text-sm font-semibold tracking-[0.3em] uppercase mb-4"
            >
              ÚNETE A NUESTRA COMUNIDAD DE ESTILO
            </p>
            <h1
              class="font-bold text-5xl md:text-6xl lg:text-7xl text-white leading-[1.1] mb-6"
            >
              BIENVENIDO AL<br />
              <span class="text-orange-500">EPICENTRO DEL</span><br />
              CUIDADO MASCULINO
            </h1>
          </div>

          <div class="space-y-2">
            <p class="text-gray-300 text-lg font-light leading-relaxed">
              Más que un corte, una declaración de principios.
            </p>
            <p class="text-gray-400 leading-relaxed">
              Accede a tu perfil para gestionar tus citas y descubrir las
              últimas tendencias en alta peluquería masculina.
            </p>
          </div>
        </div>

        <div data-reveal data-delay="1">
          <div
            class="bg-zinc-900/50 backdrop-blur-sm border border-zinc-800 rounded-2xl p-6 md:p-8"
          >
            <div class="flex gap-4 mb-8 border-b border-zinc-800">
              <button
                class="pb-3 px-1 text-gray-400 hover:text-white transition-colors"
                onclick="window.location.href='/crear-usuario'"
              >
                CREAR CUENTA
              </button>
              <button
                class="pb-3 px-1 text-orange-500 border-b-2 border-orange-500 font-medium transition-colors"
              >
                INICIAR SESIÓN
              </button>
            </div>

            <form id="user-form" class="space-y-5">
              <div>
                <label
                  for="email"
                  class="block text-gray-400 text-sm uppercase tracking-wider mb-2"
                >
                  CORREO ELECTRÓNICO
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  class="w-full bg-black/50 border border-zinc-700 text-white placeholder-gray-600 px-5 py-3.5 text-sm rounded-lg focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-all"
                />
              </div>

              <div>
                <label
                  for="password"
                  class="block text-gray-400 text-sm uppercase tracking-wider mb-2"
                >
                  CONTRASEÑA
                </label>
                <input
                  id="password"
                  name="password"
                  type="password"
                  required
                  class="w-full bg-black/50 border border-zinc-700 text-white placeholder-gray-600 px-5 py-3.5 text-sm rounded-lg focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-all"
                />
              </div>

              <button
                id="submit-user"
                type="submit"
                class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-3.5 rounded-lg transition-all duration-300 mt-6"
              >
                COMENZAR EXPERIENCIA
              </button>
              <p id="user-message" class="min-h-5 text-sm mt-4"></p>
            </form>
          </div>
        </div>
      </div>
    </div>
    <Footer />

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("user-form");
        const button = document.getElementById("submit-user");
        const message = document.getElementById("user-message");

        if (!form || !button || !message) {
          console.error("No se encontraron los elementos del formulario");
          return;
        }

        form.addEventListener("submit", async (event) => {
          event.preventDefault();

          const data = new FormData(form);

          const payload = {
            email: String(data.get("email") || ""),
            password: String(data.get("password") || ""),
          };

          button.disabled = true;
          button.textContent = "Iniciando sesión...";

          message.textContent = "";
          message.className = "min-h-5 text-sm";

          try {
            console.log("Login...", payload);

            const response = await fetch(
              "http://localhost:3000/api/auth/login",
              {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                },
                body: JSON.stringify(payload),
              },
            );

            const responseData = await response.json().catch(() => null);

            if (!response.ok) {
              throw new Error(
                responseData?.message || "Credenciales incorrectas",
              );
            }

            // Guardar la respuesta completa del backend
            localStorage.setItem(
              "legendBarberUser",
              JSON.stringify(responseData),
            );

            // Si tu API devuelve un token JWT
            if (responseData?.token) {
              localStorage.setItem("token", responseData.token);
            }

            message.textContent = "Inicio de sesión exitoso";
            message.className = "min-h-5 text-sm text-green-400";

            setTimeout(() => {
              window.location.href = "/crear-cita";
            }, 1000);
          } catch (error) {
            console.error(error);

            message.textContent =
              error instanceof Error
                ? error.message
                : "Error al iniciar sesión";

            message.className = "min-h-5 text-sm text-red-400";
          } finally {
            button.disabled = false;
            button.textContent = "COMENZAR EXPERIENCIA";
          }
        });
      });
    </script>
  </main>
</Layout>
