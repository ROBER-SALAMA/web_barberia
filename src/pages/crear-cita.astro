---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Crear cita - Legend Barber">
  <Navbar />
  <main class="min-h-screen pt-32 pb-20 bg-brand-dark">
    <section class="max-w-7xl mx-auto">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16"
        data-reveal
      >
        <div>
          <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-px bg-brand-orange"></div>
            <p
              class="text-brand-orange text-xs font-semibold tracking-[0.4em] uppercase"
            >
              Reservas
            </p>
          </div>
          <h1 class="font-display text-6xl md:text-8xl text-white leading-none">
            CREA TU
            <span class="text-brand-orange block md:inline">CITA</span>
          </h1>
        </div>
        <div
          class="bg-brand-card/30 backdrop-blur-sm border border-brand-border rounded-sm p-5 max-w-sm"
        >
          <p class="text-gray-400 text-sm leading-relaxed">
            ✂️ Selecciona servicio, barbero, fecha y hora. El resumen se
            actualiza antes de confirmar.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_420px] gap-8">
        <form id="appointment-form" class="space-y-8">
          <!-- Servicios -->
          <section
            class="group bg-brand-card border border-brand-border rounded-sm p-6 md:p-8 hover:border-brand-orange/30 transition-all duration-300"
            data-reveal
            data-delay="1"
          >
            <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
              <div class="flex items-center gap-3">
                <div class="w-1 h-6 bg-brand-orange"></div>
                <h2 class="font-heading text-2xl font-bold text-white">
                  Servicios
                </h2>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-brand-orange animate-pulse">
                </div>
                <span
                  id="services-status"
                  class="text-xs text-gray-500 tracking-widest uppercase"
                  >Cargando</span
                >
              </div>
            </div>
            <div
              id="services-list"
              class="grid grid-cols-1 md:grid-cols-2 gap-4"
            >
            </div>
          </section>

          <!-- Barberos -->
          <section
            class="group bg-brand-card border border-brand-border rounded-sm p-6 md:p-8 hover:border-brand-orange/30 transition-all duration-300"
            data-reveal
            data-delay="2"
          >
            <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
              <div class="flex items-center gap-3">
                <div class="w-1 h-6 bg-brand-orange"></div>
                <h2 class="font-heading text-2xl font-bold text-white">
                  Barberos
                </h2>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-brand-orange animate-pulse">
                </div>
                <span
                  id="barbers-status"
                  class="text-xs text-gray-500 tracking-widest uppercase"
                  >Cargando</span
                >
              </div>
            </div>
            <div
              id="barbers-list"
              class="grid grid-cols-1 md:grid-cols-2 gap-4"
            >
            </div>
          </section>

          <!-- Fecha -->
          <section
            class="bg-brand-card border border-brand-border rounded-sm p-6 md:p-8"
            data-reveal
            data-delay="3"
          >
            <div class="flex items-center gap-3 mb-6">
              <div class="w-1 h-6 bg-brand-orange"></div>
              <h2 class="font-heading text-2xl font-bold text-white">Fecha</h2>
            </div>
            <div class="relative">
              <input
                id="date"
                type="date"
                required
                class="w-full bg-brand-dark border border-brand-border text-white px-5 py-4 text-sm rounded-sm focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange/20 transition-all duration-200 cursor-pointer"
              />
              <div
                class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"
              >
                <svg
                  class="w-5 h-5 text-brand-orange"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
            </div>
          </section>

          <!-- Horario -->
          <section
            class="bg-brand-card border border-brand-border rounded-sm p-6 md:p-8"
            data-reveal
            data-delay="4"
          >
            <div class="flex items-center gap-3 mb-6">
              <div class="w-1 h-6 bg-brand-orange"></div>
              <h2 class="font-heading text-2xl font-bold text-white">
                Horario disponible
              </h2>
            </div>
            <div
              id="time-slots"
              class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3"
            >
            </div>
          </section>
        </form>

        <!-- Sidebar Resumen mejorado -->
        <aside class="relative" data-reveal data-delay="5">
          <div
            class="bg-gradient-to-br from-brand-card to-brand-dark border border-brand-border rounded-sm p-6 md:p-8 h-fit lg:sticky lg:top-28"
          >
            <!-- Badge decorativo -->
            <div
              class="absolute -top-3 right-6 bg-brand-orange px-3 py-1 rounded-sm"
            >
              <span class="text-brand-dark text-xs font-bold tracking-wide"
                >RESUMEN</span
              >
            </div>

            <div class="mt-4">
              <div class="flex items-center gap-2 mb-8">
                <div class="w-8 h-px bg-brand-orange"></div>
                <p
                  class="text-brand-orange text-xs font-semibold tracking-[0.35em] uppercase"
                >
                  Tu cita
                </p>
              </div>

              <h2 class="font-heading text-3xl font-bold text-white mb-2">
                Preparando<br />
                <span class="text-brand-orange">tu experiencia</span>
              </h2>
              <div class="w-12 h-px bg-brand-orange/50 mb-8"></div>

              <div class="space-y-5 text-sm">
                <div
                  class="group flex justify-between gap-4 border-b border-brand-border/60 pb-4 hover:border-brand-orange/30 transition-colors"
                >
                  <span class="text-gray-500 flex items-center gap-2">
                    <span class="text-brand-orange">👤</span> Cliente
                  </span>
                  <span
                    id="summary-user"
                    class="text-white text-right font-medium">Sin usuario</span
                  >
                </div>

                <div
                  class="group flex justify-between gap-4 border-b border-brand-border/60 pb-4 hover:border-brand-orange/30 transition-colors"
                >
                  <span class="text-gray-500 flex items-center gap-2">
                    <span class="text-brand-orange">✂️</span> Servicios
                  </span>
                  <span id="summary-service" class="text-white text-right"
                    >Selecciona uno o más</span
                  >
                </div>

                <div
                  class="group flex justify-between gap-4 border-b border-brand-border/60 pb-4 hover:border-brand-orange/30 transition-colors"
                >
                  <span class="text-gray-500 flex items-center gap-2">
                    <span class="text-brand-orange">💈</span> Barbero
                  </span>
                  <span id="summary-barber" class="text-white text-right"
                    >Selecciona uno</span
                  >
                </div>

                <div
                  class="group flex justify-between gap-4 border-b border-brand-border/60 pb-4 hover:border-brand-orange/30 transition-colors"
                >
                  <span class="text-gray-500 flex items-center gap-2">
                    <span class="text-brand-orange">📅</span> Fecha
                  </span>
                  <span id="summary-date" class="text-white text-right"
                    >Sin fecha</span
                  >
                </div>

                <div
                  class="group flex justify-between gap-4 border-b border-brand-border/60 pb-4 hover:border-brand-orange/30 transition-colors"
                >
                  <span class="text-gray-500 flex items-center gap-2">
                    <span class="text-brand-orange">⏰</span> Hora
                  </span>
                  <span id="summary-time" class="text-white text-right"
                    >Sin hora</span
                  >
                </div>

                <div class="flex justify-between items-end gap-4 pt-4">
                  <span class="text-gray-500 text-sm">Total</span>
                  <div class="text-right">
                    <span
                      id="summary-total"
                      class="font-display text-4xl text-brand-orange font-bold"
                      >$0.00</span
                    >
                    <p class="text-xs text-gray-600 mt-1">
                      impuestos incluidos
                    </p>
                  </div>
                </div>
              </div>

              <button
                id="create-appointment"
                type="button"
                class="btn-primary w-full mt-8 relative overflow-hidden group"
              >
                <span
                  class="relative z-10 flex items-center justify-center gap-2"
                >
                  Confirmar cita
                  <svg
                    class="w-5 h-5 transition-transform group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                  </svg>
                </span>
                <div
                  class="absolute inset-0 bg-gradient-to-r from-brand-orange to-brand-orange/80 translate-y-full group-hover:translate-y-0 transition-transform duration-300"
                >
                </div>
              </button>

              <p
                id="appointment-message"
                class="min-h-5 text-sm text-gray-400 mt-4 text-center"
              >
              </p>
            </div>
          </div>
        </aside>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const endpoints = {
    services: "http://localhost:3000/api/services",
    barbers: "http://localhost:3000/api/barbers",
    appointments: "http://localhost:3000/api/appointments",
  };

  const fallbackServices = [
    {
      id: 1,
      name: "servicon 1",
      description: "servicio 1",
      price: "1.00",
      duration: "40.00",
    },
    {
      id: 2,
      name: "servicon 2",
      description: "servicio 2",
      price: "1.00",
      duration: "40.00",
    },
  ];
  const fallbackBarbers = [{ id: 1, name: "messi", specialty: null }];
  const slots = [
    "09:00",
    "09:40",
    "10:20",
    "11:00",
    "11:40",
    "13:00",
    "13:40",
    "14:30",
    "15:10",
    "15:50",
    "16:30",
    "17:10",
  ];

  const state = {
    user: null,
    services: [],
    barbers: [],
    selectedServiceIds: [],
    selectedBarberId: null,
    date: "",
    time: "",
  };

  const servicesList = document.getElementById("services-list");
  const servicesStatus = document.getElementById("services-status");
  const barbersList = document.getElementById("barbers-list");
  const barbersStatus = document.getElementById("barbers-status");
  const dateInput = document.getElementById("date");
  const timeSlots = document.getElementById("time-slots");
  const createButton = document.getElementById("create-appointment");
  const message = document.getElementById("appointment-message");

  const summaryUser = document.getElementById("summary-user");
  const summaryService = document.getElementById("summary-service");
  const summaryBarber = document.getElementById("summary-barber");
  const summaryDate = document.getElementById("summary-date");
  const summaryTime = document.getElementById("summary-time");
  const summaryTotal = document.getElementById("summary-total");

  function money(value) {
    return `$${Number(value || 0).toFixed(2)}`;
  }

  function getSelectedServices() {
    return state.services.filter((service) =>
      state.selectedServiceIds.includes(Number(service.id)),
    );
  }

  function getSelectedBarber() {
    return state.barbers.find(
      (barber) => Number(barber.id) === Number(state.selectedBarberId),
    );
  }

  function updateSummary() {
    const services = getSelectedServices();
    const barber = getSelectedBarber();
    const total = services.reduce(
      (sum, service) => sum + Number(service.price || 0),
      0,
    );

    summaryUser.textContent = (state.user && state.user.name) || "Sin usuario";
    summaryService.textContent = services.length
      ? services.map((service) => service.name).join(", ")
      : "Selecciona uno o mas";
    summaryBarber.textContent = barber ? barber.name : "Selecciona uno";
    summaryDate.textContent = state.date || "Sin fecha";
    summaryTime.textContent = state.time || "Sin hora";
    summaryTotal.textContent = money(total);
  }

  function renderServices() {
    servicesList.innerHTML = state.services
      .map((service) => {
        const serviceId = Number(service.id);
        const checked = state.selectedServiceIds.includes(serviceId);

        return `
          <label class="service-option block border ${checked ? "border-brand-orange bg-brand-orange/10" : "border-brand-border bg-brand-dark"} rounded-sm p-5 cursor-pointer transition-all hover:border-brand-orange/70">
            <div class="flex items-start gap-4">
              <input type="checkbox" name="service" value="${service.id}" ${checked ? "checked" : ""} class="mt-1 h-4 w-4 accent-brand-orange" />
              <div class="flex-1">
                <div class="flex items-start justify-between gap-4">
                  <h3 class="font-heading text-xl font-bold text-white">${service.name}</h3>
                  <span class="font-display text-3xl text-brand-orange">${money(service.price)}</span>
                </div>
                <p class="text-sm text-gray-400 leading-relaxed mt-2">${service.description || ""}</p>
                <p class="text-xs text-gray-500 tracking-widest uppercase mt-4">${service.duration || 0} min</p>
              </div>
            </div>
          </label>
        `;
      })
      .join("");

    servicesList.querySelectorAll('input[name="service"]').forEach((input) => {
      input.addEventListener("change", () => {
        const serviceId = Number(input.value);

        if (input.checked) {
          state.selectedServiceIds = [...state.selectedServiceIds, serviceId];
        } else {
          state.selectedServiceIds = state.selectedServiceIds.filter(
            (id) => id !== serviceId,
          );
        }

        renderServices();
        updateSummary();
      });
    });
  }

  function renderBarbers() {
    barbersList.innerHTML = state.barbers
      .map((barber) => {
        const checked = Number(barber.id) === Number(state.selectedBarberId);

        return `
          <label class="barber-option block border ${checked ? "border-brand-orange bg-brand-orange/10" : "border-brand-border bg-brand-dark"} rounded-sm p-5 cursor-pointer transition-all hover:border-brand-orange/70">
            <div class="flex items-start gap-4">
              <input type="radio" name="barber" value="${barber.id}" ${checked ? "checked" : ""} class="mt-1 h-4 w-4 accent-brand-orange" />
              <div class="flex-1">
                <div class="flex items-start justify-between gap-4">
                  <h3 class="font-heading text-xl font-bold text-white">${barber.name}</h3>
                  <span class="material-icons text-brand-orange">content_cut</span>
                </div>
                <p class="text-sm text-gray-400 leading-relaxed mt-2">${barber.specialty || "Barbero disponible"}</p>
              </div>
            </div>
          </label>
        `;
      })
      .join("");

    barbersList.querySelectorAll('input[name="barber"]').forEach((input) => {
      input.addEventListener("change", () => {
        state.selectedBarberId = Number(input.value);
        renderBarbers();
        updateSummary();
      });
    });
  }

  function renderSlots() {
    timeSlots.innerHTML = slots
      .map((slot) => {
        const active = slot === state.time;

        return `
          <button type="button" data-time="${slot}" class="time-slot border ${active ? "border-brand-orange bg-brand-orange text-white" : "border-brand-border bg-brand-dark text-gray-300"} rounded-sm px-4 py-3 text-sm font-semibold transition-all hover:border-brand-orange hover:text-white">
            ${slot}
          </button>
        `;
      })
      .join("");

    timeSlots.querySelectorAll(".time-slot").forEach((button) => {
      button.addEventListener("click", () => {
        state.time = button.getAttribute("data-time") || "";
        renderSlots();
        updateSummary();
      });
    });
  }

  async function fetchList(url, fallback) {
    try {
      const response = await fetch(url);

      if (!response.ok) {
        throw new Error("Request failed");
      }

      return await response.json();
    } catch (error) {
      return fallback;
    }
  }

  async function boot() {
    const storedUser = localStorage.getItem("legendBarberUser");
    const parsed = storedUser ? JSON.parse(storedUser) : null;
    state.user = parsed?.user ?? parsed;

    if (!state.user) {
      window.location.href = "/crear-usuario";
      return;
    }

    const today = new Date().toISOString().slice(0, 10);
    dateInput.min = today;
    dateInput.value = "2026-06-15";
    state.date = dateInput.value;

    const lists = await Promise.all([
      fetchList(endpoints.services, fallbackServices),
      fetchList(endpoints.barbers, fallbackBarbers),
    ]);

    state.services = lists[0];
    state.barbers = lists[1];
    state.selectedServiceIds = state.services[0]
      ? [Number(state.services[0].id)]
      : [];
    state.selectedBarberId = state.barbers[0] ? state.barbers[0].id : null;
    state.time = "14:30";

    servicesStatus.textContent = `${state.services.length} disponibles`;
    barbersStatus.textContent = `${state.barbers.length} disponibles`;
    renderServices();
    renderBarbers();
    renderSlots();
    updateSummary();
  }

  dateInput.addEventListener("change", () => {
    state.date = dateInput.value;
    updateSummary();
  });

  createButton.addEventListener("click", async () => {
    const userId = (state.user && state.user.id) || 1;
    const services = getSelectedServices();
    const barber = getSelectedBarber();

    if (!services.length || !barber || !state.date || !state.time) {
      message.textContent = "Completa servicios, barbero, fecha y hora.";
      message.className = "min-h-5 text-sm text-red-400 mt-4";
      return;
    }

    const selectedServiceIds = services.map((service) => Number(service.id));
    const payload = {
      userId: Number(userId),
      barberId: Number(barber.id),
      serviceId: selectedServiceIds[0],
      date: state.date,
      time: state.time,
      status: "en_proceso",
      services: selectedServiceIds,
    };

    createButton.disabled = true;
    createButton.textContent = "Creando cita...";
    message.textContent = "";

    try {
      const response = await fetch(endpoints.appointments, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error("No se pudo crear la cita");
      }

      const appointment = await response.json().catch(() => payload);
      localStorage.setItem(
        "legendBarberAppointment",
        JSON.stringify({ ...payload, ...appointment }),
      );
      message.textContent = "Cita creada correctamente.";
      message.className = "min-h-5 text-sm text-brand-orange mt-4";
      alert("✅ ¡Cita creada correctamente!");
      window.location.reload();
    } catch (error) {
      message.textContent =
        error instanceof Error ? error.message : "Error al crear la cita";
      message.className = "min-h-5 text-sm text-red-400 mt-4";
    } finally {
      createButton.disabled = false;
      createButton.textContent = "Crear cita";
    }
  });

  boot();
</script>

<style is:global>
  /* Animaciones personalizadas */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  [data-reveal] {
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }

  [data-reveal][data-delay="1"] {
    animation-delay: 0.1s;
  }
  [data-reveal][data-delay="2"] {
    animation-delay: 0.2s;
  }
  [data-reveal][data-delay="3"] {
    animation-delay: 0.3s;
  }
  [data-reveal][data-delay="4"] {
    animation-delay: 0.4s;
  }
  [data-reveal][data-delay="5"] {
    animation-delay: 0.5s;
  }

  /* Estilos para los botones de servicio/barbero */
  .service-card,
  .barber-card {
    transition: all 0.2s ease;
  }

  .service-card.selected,
  .barber-card.selected {
    background: linear-gradient(
      135deg,
      rgba(234, 88, 12, 0.15),
      rgba(234, 88, 12, 0.05)
    );
    border-color: #ea580c;
    box-shadow: 0 0 0 1px #ea580c;
  }

  /* Estilos para slots de tiempo */
  .time-slot {
    transition: all 0.2s ease;
  }

  .time-slot.selected {
    background: #ea580c;
    border-color: #ea580c;
    color: white;
    transform: scale(0.98);
  }

  /* Botón principal */
  .btn-primary {
    background: transparent;
    border: 1px solid #ea580c;
    color: #ea580c;
    padding: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: #ea580c;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(234, 88, 12, 0.4);
  }
</style>
